{
  "rules": {
    "appUpdateConfig": {
      ".read": "auth !== null",
      ".write": "false"
    },
    "haptics": {
      "$conversationId": {
        ".read": "auth !== null && root.child('userConversationsIndex').child(auth.uid).child($conversationId).val() === true",
        ".write": "false"
      }
    },
    "userConversations": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "false"
      }
    },
    "userConversationsIndex": {
      "$userId": {
        ".read": "false",
        ".write": "false"
      }
    },
    "userBlocks": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "false"
      }
    },
    "requests": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "false"
      }
    },
    "invites": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "false"
      }
    }
  }
}
