// Shared project configuration. Copy Secrets.xcconfig.example to Secrets.xcconfig
// and fill in the local values before building.
#include? "Secrets.xcconfig"

HAPTICS_GOOGLE_SERVICE_INFO_PLIST_SOURCE = $(SRCROOT)/Haptics/GoogleService-Info.plist
WIDGETS_GOOGLE_SERVICE_INFO_PLIST_SOURCE = $(SRCROOT)/Widgets/GoogleService-Info.plist
AYO_INTENT_EXTENSION_GOOGLE_SERVICE_INFO_PLIST_SOURCE = $(SRCROOT)/AyoIntentExtension/GoogleService-Info.plist

AYO_WIDGET_KIND = $(WIDGETS_BUNDLE_IDENTIFIER).Ayo
